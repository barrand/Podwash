.idea/
.vscode/

# Secrets / local config
.env
.env.*
*.xcconfig.local

# Audio: large media ignored by default...
*.m4a
*.mp3
*.wav

# ...but small test fixtures ARE committed (keep fixture audio under ~1 MB each;
# document local setup for anything larger instead of committing it)
!PodWash/PodWashTests/Fixtures/**
!PodWash/PodWashUITests/Fixtures/**
!PodWash/PodWash/Fixtures/**

# ASR models are never committed (downloaded by scripts/setup-asr-models.sh)
Models/

# Ad detection eval harness (downloaded audio + transcripts)
tmp/ad-eval/
